<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta charset="utf-8">
<title>PsExec Panel</title>
<HTA:APPLICATION
  ID="PsExecPanel"
  APPLICATIONNAME="PsExec Panel"
  BORDER="thick"
  BORDERSTYLE="normal"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
  SCROLL="no"
  WINDOWSTATE="normal"
/>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    height: 100%;
    font-family: "Segoe UI", Tahoma, sans-serif;
    font-size: 13px;
    color: #e6e6e6;
    background: #1e1e1e;
    overflow: hidden;
  }
  #app {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 12px;
    gap: 10px;
  }
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #333;
    padding-bottom: 8px;
  }
  header h1 {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }
  #configPath {
    font-size: 11px;
    color: #888;
  }
  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    background: #252526;
    border: 1px solid #333;
    border-radius: 6px;
    padding: 10px;
  }
  .group {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .group label { color: #aaa; white-space: nowrap; }
  select, input[type="text"] {
    background: #1e1e1e;
    color: #e6e6e6;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
  }
  select { min-width: 110px; }
  #templateSelect { min-width: 180px; max-width: 260px; }
  #searchBox { width: 140px; }
  .flags label {
    color: #ccc;
    margin-right: 4px;
    cursor: pointer;
  }
  button {
    background: #0e639c;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 12px;
    cursor: pointer;
  }
  button:hover { background: #1177bb; }
  button.secondary {
    background: #3c3c3c;
  }
  button.secondary:hover { background: #4a4a4a; }
  button.connect {
    background: #16825d;
    font-weight: 600;
  }
  button.connect:hover { background: #1a9d70; }
  .spacer { flex: 1; }
  #preview {
    font-family: Consolas, "Courier New", monospace;
    font-size: 11px;
    color: #ce9178;
    background: #111;
    border: 1px solid #333;
    border-radius: 4px;
    padding: 6px 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #tableWrap {
    flex: 1;
    overflow: auto;
    border: 1px solid #333;
    border-radius: 6px;
    background: #252526;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  thead th {
    position: sticky;
    top: 0;
    background: #2d2d30;
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid #444;
    color: #ccc;
    font-weight: 600;
  }
  thead th.check,
  tbody td.check {
    width: 36px;
    text-align: center;
    padding-left: 8px;
    padding-right: 8px;
  }
  tbody td {
    padding: 7px 12px;
    border-bottom: 1px solid #2a2a2a;
    cursor: pointer;
  }
  tbody tr:hover { background: #2a2d2e; }
  tbody tr.selected { background: #094771; }
  tbody tr.selected:hover { background: #0a5a8a; }
  #log {
    height: 90px;
    overflow: auto;
    background: #111;
    border: 1px solid #333;
    border-radius: 6px;
    padding: 8px 10px;
    font-family: Consolas, "Courier New", monospace;
    font-size: 11px;
    color: #9cdcfe;
    white-space: pre-wrap;
    word-break: break-all;
  }
  #log .err { color: #f48771; }
  #log .ok { color: #4ec9b0; }
  #log .cmd { color: #ce9178; }
</style>
<script language="JScript">
var g_baseDir = "";
var g_pcs = [];
var g_templates = [];
var g_checked = {};
var g_focusIdx = -1;
var g_config = { path: "", username: "", password: "" };

function onLoad() {
  try {
    window.resizeTo(920, 620);
    window.moveTo(
      Math.max(0, (screen.availWidth - 920) / 2),
      Math.max(0, (screen.availHeight - 620) / 2)
    );
  } catch (e) {}

  g_baseDir = getBaseDir();
  document.getElementById("configPath").innerText = g_baseDir;
  loadConfig();
  loadTemplates();
  loadPcs();
  renderTemplates();
  renderTable();
  updatePreview();
  log("Ready. Config: " + g_baseDir + "config.ini", "ok");
}

function getBaseDir() {
  var path = unescape(location.pathname);
  if (path.charAt(0) === "/") path = path.substring(1);
  path = path.replace(/\//g, "\\");
  var i = path.lastIndexOf("\\");
  if (i >= 0) return path.substring(0, i + 1);
  return "";
}

function loadConfig() {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var cfgPath = g_baseDir + "config.ini";
  g_config = { path: "", username: "", password: "" };

  if (!fso.FileExists(cfgPath)) {
    log("config.ini not found: " + cfgPath, "err");
    return;
  }

  var ts = fso.OpenTextFile(cfgPath, 1);
  var content = ts.ReadAll();
  ts.Close();

  var lines = content.split(/\r?\n/);
  for (var i = 0; i < lines.length; i++) {
    var line = trim(lines[i]);
    if (!line || line.charAt(0) === ";" || line.charAt(0) === "#" || line.charAt(0) === "[") continue;
    var eq = line.indexOf("=");
    if (eq < 0) continue;
    var key = trim(line.substring(0, eq)).toLowerCase();
    var val = trim(line.substring(eq + 1));
    if (key === "path") g_config.path = val;
    else if (key === "username") g_config.username = val;
    else if (key === "password") g_config.password = val;
  }

  if (!g_config.path) {
    log("PsExec Path is empty in config.ini", "err");
  } else {
    log("PsExec path: " + g_config.path, "ok");
  }
}

function loadPcs() {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var csvPath = g_baseDir + "pcs.csv";
  var prevChecked = g_checked;
  g_pcs = [];
  g_checked = {};
  g_focusIdx = -1;

  if (!fso.FileExists(csvPath)) {
    log("pcs.csv not found: " + csvPath, "err");
    return;
  }

  var ts = fso.OpenTextFile(csvPath, 1);
  var first = true;
  while (!ts.AtEndOfStream) {
    var line = ts.ReadLine();
    if (first) {
      first = false;
      continue;
    }
    line = trim(line);
    if (!line) continue;
    var parts = parseCsvLine(line);
    var name = trim(parts[0] || "");
    var notes = trim(parts[1] || "");
    if (name) {
      g_pcs.push({ name: name, notes: notes });
      if (prevChecked[name]) g_checked[name] = true;
    }
  }
  ts.Close();
  log("Loaded " + g_pcs.length + " PC(s) from pcs.csv", "ok");
}

function loadTemplates() {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var csvPath = g_baseDir + "templates.csv";
  g_templates = [];

  if (!fso.FileExists(csvPath)) {
    g_templates.push({ name: "Interactive shell", command: "" });
    log("templates.csv not found; using Interactive shell only", "err");
    return;
  }

  var ts = fso.OpenTextFile(csvPath, 1);
  var first = true;
  while (!ts.AtEndOfStream) {
    var line = ts.ReadLine();
    if (first) {
      first = false;
      continue;
    }
    line = trim(line);
    if (!line) continue;
    var parts = parseCsvLine(line);
    var name = trim(parts[0] || "");
    var command = trim(parts[1] || "");
    if (name) g_templates.push({ name: name, command: command });
  }
  ts.Close();

  if (g_templates.length === 0) {
    g_templates.push({ name: "Interactive shell", command: "" });
  }
  log("Loaded " + g_templates.length + " template(s)", "ok");
}

function parseCsvLine(line) {
  var result = [];
  var cur = "";
  var inQuotes = false;
  for (var i = 0; i < line.length; i++) {
    var c = line.charAt(i);
    if (inQuotes) {
      if (c === "\"") {
        if (i + 1 < line.length && line.charAt(i + 1) === "\"") {
          cur += "\"";
          i++;
        } else {
          inQuotes = false;
        }
      } else {
        cur += c;
      }
    } else {
      if (c === "\"") inQuotes = true;
      else if (c === ",") {
        result.push(cur);
        cur = "";
      } else {
        cur += c;
      }
    }
  }
  result.push(cur);
  return result;
}

function trim(s) {
  return String(s).replace(/^\s+|\s+$/g, "");
}

function getFilter() {
  return trim(document.getElementById("searchBox").value).toLowerCase();
}

function filteredPcs() {
  var q = getFilter();
  if (!q) return g_pcs;
  var out = [];
  for (var i = 0; i < g_pcs.length; i++) {
    var p = g_pcs[i];
    if (p.name.toLowerCase().indexOf(q) >= 0 || p.notes.toLowerCase().indexOf(q) >= 0) {
      out.push(p);
    }
  }
  return out;
}

function renderTemplates() {
  var sel = document.getElementById("templateSelect");
  var prev = sel.value;
  sel.innerHTML = "";
  for (var i = 0; i < g_templates.length; i++) {
    var opt = document.createElement("option");
    opt.value = String(i);
    opt.innerText = g_templates[i].name;
    sel.appendChild(opt);
  }
  if (prev !== "" && parseInt(prev, 10) < g_templates.length) {
    sel.value = prev;
  } else {
    sel.selectedIndex = 0;
  }
}

function getSelectedTemplate() {
  var idx = parseInt(document.getElementById("templateSelect").value, 10);
  if (isNaN(idx) || idx < 0 || idx >= g_templates.length) {
    return { name: "Interactive shell", command: "" };
  }
  return g_templates[idx];
}

function updatePreview() {
  var t = getSelectedTemplate();
  var shell = document.getElementById("shellType").value;
  var remote = buildRemotePayload(shell, t.command);
  var el = document.getElementById("preview");
  if (!t.command) {
    el.innerText = "Remote: interactive " + (shell === "powershell" ? "PowerShell" : "CMD");
  } else {
    el.innerText = "Remote: " + remote;
  }
  el.title = el.innerText;
}

function renderTable() {
  var tbody = document.getElementById("pcBody");
  tbody.innerHTML = "";
  var list = filteredPcs();
  var focusName = (g_focusIdx >= 0 && g_focusIdx < g_pcs.length) ? g_pcs[g_focusIdx].name : "";

  for (var i = 0; i < list.length; i++) {
    var p = list[i];
    var realIdx = indexOfPc(p.name);
    var tr = document.createElement("tr");
    if (p.name === focusName) tr.className = "selected";
    tr.setAttribute("data-idx", String(realIdx));

    var tdCheck = document.createElement("td");
    tdCheck.className = "check";
    var cb = document.createElement("input");
    cb.type = "checkbox";
    cb.checked = !!g_checked[p.name];
    cb.onclick = makeCheckHandler(p.name, cb);
    tdCheck.appendChild(cb);

    var tdName = document.createElement("td");
    tdName.innerText = p.name;
    var tdNotes = document.createElement("td");
    tdNotes.innerText = p.notes;

    tr.onclick = makeRowClickHandler(realIdx, p.name);
    tr.ondblclick = makeConnectHandler(realIdx, p.name);

    tr.appendChild(tdCheck);
    tr.appendChild(tdName);
    tr.appendChild(tdNotes);
    tbody.appendChild(tr);
  }

  updateSelectAllState();
}

function indexOfPc(name) {
  for (var i = 0; i < g_pcs.length; i++) {
    if (g_pcs[i].name === name) return i;
  }
  return -1;
}

function makeCheckHandler(name, cb) {
  return function (e) {
    if (e && e.stopPropagation) e.stopPropagation();
    g_checked[name] = !!cb.checked;
    if (!cb.checked) delete g_checked[name];
    updateSelectAllState();
  };
}

function makeRowClickHandler(idx, name) {
  return function (e) {
    var t = e ? e.srcElement || e.target : null;
    if (t && t.tagName && t.tagName.toLowerCase() === "input") return;
    g_focusIdx = idx;
    renderTable();
  };
}

function makeConnectHandler(idx, name) {
  return function (e) {
    var t = e ? e.srcElement || e.target : null;
    if (t && t.tagName && t.tagName.toLowerCase() === "input") return;
    g_focusIdx = idx;
    g_checked = {};
    g_checked[name] = true;
    renderTable();
    connect();
  };
}

function updateSelectAllState() {
  var list = filteredPcs();
  var all = list.length > 0;
  for (var i = 0; i < list.length; i++) {
    if (!g_checked[list[i].name]) {
      all = false;
      break;
    }
  }
  var hdr = document.getElementById("chkAll");
  if (hdr) hdr.checked = all;
}

function toggleSelectAll() {
  var hdr = document.getElementById("chkAll");
  var list = filteredPcs();
  var on = hdr && hdr.checked;
  for (var i = 0; i < list.length; i++) {
    if (on) g_checked[list[i].name] = true;
    else delete g_checked[list[i].name];
  }
  renderTable();
}

function selectAllFiltered() {
  var list = filteredPcs();
  for (var i = 0; i < list.length; i++) {
    g_checked[list[i].name] = true;
  }
  renderTable();
}

function clearSelection() {
  g_checked = {};
  g_focusIdx = -1;
  renderTable();
}

function getTargetPcs() {
  var names = [];
  for (var i = 0; i < g_pcs.length; i++) {
    if (g_checked[g_pcs[i].name]) names.push(g_pcs[i].name);
  }
  if (names.length === 0 && g_focusIdx >= 0 && g_focusIdx < g_pcs.length) {
    names.push(g_pcs[g_focusIdx].name);
  }
  return names;
}

function onSearch() {
  renderTable();
}

function reloadList() {
  loadConfig();
  loadTemplates();
  loadPcs();
  renderTemplates();
  renderTable();
  updatePreview();
}

function quoteArg(s) {
  s = String(s);
  if (s.indexOf(" ") >= 0 || s.indexOf("\"") >= 0 || s.indexOf("&") >= 0) {
    return "\"" + s.replace(/\"/g, "\\\"") + "\"";
  }
  return s;
}

function escapeForPsSingleQuoted(s) {
  return String(s).replace(/'/g, "''");
}

function buildRemotePayload(shell, templateCmd) {
  if (!templateCmd) {
    return (shell === "powershell") ? "powershell" : "cmd";
  }
  if (shell === "powershell") {
    return "powershell -NoProfile -ExecutionPolicy Bypass -Command \"" +
      templateCmd.replace(/\\/g, "\\\\").replace(/\"/g, "\\\"") + "\"";
  }
  return "cmd /c " + quoteArg(templateCmd);
}

function buildCommand(pcName) {
  if (!g_config.path) {
    throw new Error("PsExec path not set in config.ini");
  }

  var shell = document.getElementById("shellType").value;
  var t = getSelectedTemplate();
  var remote = buildRemotePayload(shell, t.command);

  var parts = [];
  parts.push(quoteArg(g_config.path));
  parts.push("\\\\" + pcName);

  if (g_config.username) {
    parts.push("-u");
    parts.push(quoteArg(g_config.username));
    if (g_config.password) {
      parts.push("-p");
      parts.push(quoteArg(g_config.password));
    }
  }

  if (document.getElementById("flagS").checked) parts.push("-s");
  if (document.getElementById("flagI").checked) parts.push("-i");
  if (document.getElementById("flagH").checked) parts.push("-h");

  parts.push(remote);
  return parts.join(" ");
}

function redactCmd(cmd) {
  var safe = cmd;
  if (g_config.password) {
    safe = safe.split(quoteArg(g_config.password)).join("********");
    safe = safe.split(g_config.password).join("********");
  }
  return safe;
}

function pad2(n) {
  return ("0" + n).slice(-2);
}

function formatDateTimeStamp(d) {
  return d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate()) + "_" +
    pad2(d.getHours()) + pad2(d.getMinutes()) + pad2(d.getSeconds());
}

function sanitizeFileName(s) {
  return String(s).replace(/[\\\/:\*\?"<>\|]/g, "_");
}

function ensureLogDir() {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var dir = g_baseDir + "Log";
  if (!fso.FolderExists(dir)) {
    fso.CreateFolder(dir);
  }
  return dir + "\\";
}

function makeLogPath(pcName) {
  return ensureLogDir() + sanitizeFileName(pcName) + "_" + formatDateTimeStamp(new Date()) + ".log";
}

function writeTextFile(path, content, append) {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var ts = fso.OpenTextFile(path, append ? 8 : 2, true);
  ts.Write(content);
  ts.Close();
}

function writeLogHeader(logPath, pc, templateName, redactedCmd) {
  var t = new Date();
  var lines = [
    "=== PsExec Panel Log ===",
    "Time: " + t.toString(),
    "Host: " + pc,
    "Template: " + templateName,
    "Command: " + redactedCmd,
    "========================",
    ""
  ];
  writeTextFile(logPath, lines.join("\r\n"), false);
}

function createLaunchBatch(psexecCmd, logPath, pauseAfter) {
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var tempDir = fso.GetSpecialFolder(2).Path;
  var batchPath = tempDir + "\\PsExecPanel_" + formatDateTimeStamp(new Date()) + "_" +
    Math.floor(Math.random() * 100000) + ".cmd";
  var cmdLine = String(psexecCmd).replace(/%/g, "%%");
  var lines = [
    "@echo off",
    cmdLine + " >> " + quoteArg(logPath) + " 2>&1"
  ];
  if (pauseAfter) {
    lines.push("echo.");
    lines.push("type " + quoteArg(logPath));
    lines.push("echo.");
    lines.push("pause");
  }
  writeTextFile(batchPath, lines.join("\r\n") + "\r\n", false);
  return batchPath;
}

function connect() {
  var targets = getTargetPcs();
  if (targets.length === 0) {
    log("Select at least one PC (checkbox or row).", "err");
    return;
  }

  var t = getSelectedTemplate();
  if (targets.length > 1) {
    var msg = "Run \"" + t.name + "\" on " + targets.length + " PC(s)?\n\n" + targets.join("\n");
    if (!confirm(msg)) {
      log("Batch cancelled.", "err");
      return;
    }
  }

  var wait = document.getElementById("flagWait").checked;
  var hasTemplateCmd = !!(t.command && String(t.command).length);
  var sh;
  try {
    sh = new ActiveXObject("WScript.Shell");
  } catch (e) {
    log("Failed to create WScript.Shell: " + (e.message || e), "err");
    return;
  }

  try {
    ensureLogDir();
  } catch (e) {
    log("Failed to create Log folder: " + (e.message || e), "err");
    return;
  }

  log("Template: " + t.name + " | Targets: " + targets.length + (wait ? " (wait)" : " (parallel)"), "ok");

  var ok = 0;
  var fail = 0;
  for (var i = 0; i < targets.length; i++) {
    var pc = targets[i];
    var cmd;
    try {
      cmd = buildCommand(pc);
    } catch (e) {
      log(pc + ": " + (e.message || e), "err");
      fail++;
      continue;
    }

    var redacted = redactCmd(cmd);
    log("[" + (i + 1) + "/" + targets.length + "] " + pc, "ok");
    log(redacted, "cmd");

    var logPath;
    var launchCmd = cmd;
    try {
      logPath = makeLogPath(pc);
      writeLogHeader(logPath, pc, t.name, redacted);
      if (hasTemplateCmd) {
        launchCmd = quoteArg(createLaunchBatch(cmd, logPath, true));
      } else {
        writeTextFile(logPath, "Interactive session launched (console output not captured).\r\n", true);
      }
    } catch (e) {
      log(pc + " log setup failed: " + (e.message || e), "err");
      fail++;
      continue;
    }

    try {
      sh.Run(launchCmd, 1, wait);
      ok++;
      log("Launched: " + pc, "ok");
      log("Log: " + logPath, "ok");
    } catch (e) {
      fail++;
      log("Failed " + pc + ": " + (e.message || e), "err");
    }
  }

  log("Done. Launched " + ok + "/" + targets.length + (fail ? (" (" + fail + " failed)") : ""), fail ? "err" : "ok");
}

function log(msg, cls) {
  var el = document.getElementById("log");
  var line = document.createElement("div");
  if (cls) line.className = cls;
  var t = new Date();
  var hh = ("0" + t.getHours()).slice(-2);
  var mm = ("0" + t.getMinutes()).slice(-2);
  var ss = ("0" + t.getSeconds()).slice(-2);
  line.innerText = "[" + hh + ":" + mm + ":" + ss + "] " + msg;
  el.appendChild(line);
  el.scrollTop = el.scrollHeight;
}
</script>
</head>
<body onload="onLoad()">
  <div id="app">
    <header>
      <h1>PsExec Fast Connect</h1>
      <span id="configPath"></span>
    </header>

    <div class="toolbar">
      <div class="group">
        <label for="shellType">Shell</label>
        <select id="shellType" onchange="updatePreview()">
          <option value="powershell" selected>PowerShell</option>
          <option value="cmd">CMD</option>
        </select>
      </div>

      <div class="group">
        <label for="templateSelect">Template</label>
        <select id="templateSelect" onchange="updatePreview()"></select>
      </div>

      <div class="group flags">
        <label><input type="checkbox" id="flagS"> -s</label>
        <label><input type="checkbox" id="flagI" checked> -i</label>
        <label><input type="checkbox" id="flagH"> -h</label>
        <label><input type="checkbox" id="flagWait"> Wait</label>
      </div>

      <div class="group">
        <label for="searchBox">Search</label>
        <input type="text" id="searchBox" onkeyup="onSearch()" placeholder="Name or notes...">
      </div>

      <span class="spacer"></span>

      <button class="secondary" onclick="selectAllFiltered()">Select all</button>
      <button class="secondary" onclick="clearSelection()">Clear</button>
      <button class="secondary" onclick="reloadList()">Reload</button>
      <button class="connect" onclick="connect()">Connect</button>
    </div>

    <div id="preview">Remote: interactive PowerShell</div>

    <div id="tableWrap">
      <table>
        <thead>
          <tr>
            <th class="check"><input type="checkbox" id="chkAll" onclick="toggleSelectAll()" title="Select all filtered"></th>
            <th style="width:38%">Name</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody id="pcBody"></tbody>
      </table>
    </div>

    <div id="log"></div>
  </div>
</body>
</html>
